# App Configuration
NODE_ENV=development
APP_PORT=3000
APP_NAME=ReviTurnos Backend
APP_URL=http://localhost:3000
MERCADOPAGO_NOTIFICATION_BASE_URL=http://localhost:3000

# Database PostgreSQL
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=reviturnos
DB_PASSWORD=reviturnos_password_2026
DB_DATABASE=reviturnos
DB_SYNCHRONIZE=false
DB_LOGGING=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=365d

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS
CORS_ORIGIN=http://localhost:3001,https://turnos.reviturnos.com.ar

# Logging
LOG_LEVEL=debug
LOG_DIR=./logs
